{
  "name": "chunk-scroll-table",
  "version": "0.1.0",
  "description": "Lightweight virtual table with chunk-based server-side loading, caching, prefetching, and button navigation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "virtual-scroll",
    "table",
    "chunk-loading",
    "infinite-scroll",
    "pagination",
    "vanilla-js"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "happy-dom": "^20.8.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
